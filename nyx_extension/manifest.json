{
  "manifest_version": 3,
  "name": "Nyx v6",
  "version": "6.0.3",
  "version_name": "6.0.3",
  "description": "Detect AdsPower IDs and models from SnapBoard and sync them into the Nyx queue.",
  "key": "",
  "permissions": [
    "storage",
    "alarms",
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://snapboard.onrender.com/*",
    "https://www.snapchat.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons8-origami-50.png",
    "32": "icons8-origami-50.png",
    "48": "icons8-origami-50.png",
    "128": "icons8-origami-50.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://snapboard.onrender.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.snapchat.com/@*"
      ],
      "js": [
        "content_snapchat.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Nyx v6",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons8-origami-50.png",
      "32": "icons8-origami-50.png",
      "48": "icons8-origami-50.png"
    }
  },
  "options_page": "options.html"
}
